generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String

  savedColleges SavedCollege[]
}

model College {
  id          Int      @id @default(autoincrement())
  name        String
  location    String
  fees        Float
  rating      Float

  courses     Course[]
  reviews     Review[]

  savedBy     SavedCollege[]
}

model Course {
  id          Int      @id @default(autoincrement())
  name        String

  collegeId   Int
  college     College @relation(fields: [collegeId], references: [id])
}

model Review {
  id          Int      @id @default(autoincrement())
  comment     String
  rating      Float

  collegeId   Int
  college     College @relation(fields: [collegeId], references: [id])
}

model SavedCollege {
  id          Int      @id @default(autoincrement())

  userId      Int
  collegeId   Int

  user        User    @relation(fields: [userId], references: [id])
  college     College @relation(fields: [collegeId], references: [id])

  @@unique([userId, collegeId])
}